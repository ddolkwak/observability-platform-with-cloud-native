apiVersion: v1
kind: Service
metadata:
  name: postgres-service
  namespace: "{{ pg_namespace }}"
  labels:
    app: postgres
spec:
  selector:
    app: postgres
  ports:
    - name: tcp-postgres
      protocol: TCP
      port: {{ pg_port }}
      targetPort: {{ pg_port }}
  type: "{{ pg_svc_type }}"
