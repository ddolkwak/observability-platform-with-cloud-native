apiVersion: metallb.io/v1beta1
kind: IPAddressPool
metadata:
  name: ip-address-pool
  namespace: {{ metallb-namespace }}
spec:
  addresses:
{% for ip_range in metallb_ip_pools %}
  - {{ ip_range }}
{% endfor %}
---
apiVersion: metallb.io/v1beta1
kind: L2Advertisement
metadata:
  name: l2-adv
  namespace: {{ metallb_namespace }}
spec:
  ipAddressPools:
  - ip-address-pool
